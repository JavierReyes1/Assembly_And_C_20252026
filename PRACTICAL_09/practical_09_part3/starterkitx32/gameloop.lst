   256                                  ;------------------------------------------------------- 
   257                                  gameplay:
   258 000001F8 E86AFEFFFF                  call    write_endl                  ; write ENDL
   259 000001FD B9[A4010000]                mov     ecx, gameplay_msg           ; message 32 Bit Register
   260 00000202 BA0E000000                  mov     edx, len_gameplay_msg       ; message length see length equ 32 Bit Register
   261 00000207 E841FEFFFF                  call    sys_write                   ; call sys_write   
   262 0000020C E856FEFFFF                  call    write_endl                  ; write ENDL
   263 00000211 C3                          ret                                 ; RETURN FROM DRAW: SUBROUTINE
   264                                  
   265                                  ;-------------------------------------------------------
   266                                  ;------------HEADS UP DISPLAY (SCORE & \HEALTH)---------
   267                                  ; RETRIEVES THE SCORE FROM MEMORY LOCATION
   268                                  ; RETRIEVES THE HEALTH FROM MEMORY LOCATION
   269                                  ;-------------------------------------------------------   
   270                                  hud:
   271 00000212 E806000000                  call    .hud_score                  ; print score
