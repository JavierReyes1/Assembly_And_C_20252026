   311                                  ;-------------------------------------------------------
   312                                  ;----------------------Continue-------------------------
   313                                  ;-------------------------------------------------------
   314                                  write_continue:
   315 00000282 E8E0FDFFFF                  call    write_endl                  ; write ENDL
   316 00000287 B9[DE000000]                mov     ecx, continue_msg           ; message 32 Bit Register
   317 0000028C BA23000000                  mov     edx, len_continue_msg       ; message length see length equ 32 Bit Register
   318 00000291 E8B7FDFFFF                  call    sys_write                   ; call sys_write  
   319 00000296 C3                          ret                                 ; return
   320                                  ;-------------------------------------------------------
   321                                  ;------------------------REPLAY-------------------------
   322                                  ;-------------------------------------------------------
   323                                  replay:
   324 00000297 E8CBFDFFFF                  call    write_endl                  ; write ENDL
   325 0000029C B9[18020000]                mov     ecx, replay_msg             ; message 32 Bit Register
   326 000002A1 BA2D000000                  mov     edx, len_replay_msg         ; message length see length equ 32 Bit Register
   327 000002A6 E8A2FDFFFF                  call    sys_write                   ; call sys_write
   328 000002AB B9[01000000]                mov     ecx, action                 ; move input to action  
   329 000002B0 BA01000000                  mov     edx, 1                      ; size of input
   330 000002B5 E8A0FDFFFF                  call    sys_read                    ; call sys_read
   331 000002BA 89CB                        mov     ebx, ecx                    ; move to compare input
   332 000002BC 803B30                      cmp     byte [ebx], 0x30            ; compare value in register with 0x30 Hex ASCII for 0
   333 000002BF 0F855CFEFFFF                jne     gameloop                    ; jump tp gameloop if not equals 0
   334 000002C5 E89DFDFFFF                  call    write_endl                  ; write ENDL
   335 000002CA C3                          ret                                 ; RETURN FROM REPLAY: SUBROUTINE
   336                                  
   337                                  ;-------------------------------------------------------
   338                                  ;------------------SCREEN DECORATION--------------------
   339                                  ;-------------------------------------------------------
   340                                  decorate:
   341 000002CB E897FDFFFF                  call    write_endl                  ; write ENDL
   342 000002D0 B9[DC010000]                mov     ecx, loop_msg               ; message 32 Bit Register
   343 000002D5 BA3C000000                  mov     edx, len_loop_msg           ; message length see length equ 32 Bit Register
   344 000002DA E86EFDFFFF                  call    sys_write                   ; call sys_write
   345 000002DF E883FDFFFF                  call    write_endl                  ; write ENDL
   346 000002E4 C3                          ret                                 ; RETURN FROM DECORATE: SUBROUTINE
   347                                  
   348                                  ;-------------------------------------------------------
   349                                  ;---------------Collision Detection (Attacked)----------
   350                                  ; This procedure is used for collision detection
   351                                  ;-------------------------------------------------------
   352                                  collision:
   353 000002E5 31DB                        xor     ebx, ebx                    ; clear ebx
   354 000002E7 BB64000000                  mov     ebx, MINE_LOC               ; move ordinace location into ebx
   355 000002EC 83FB64                      cmp     ebx, 0x64                   ; compare value in register with 0x64 100,ebx IS( X == 100)?
   356 000002EF 751A                    	jne     collision_miss              ; COLLISION_MISS IF X IS NOT EQUAL TO 100, OTHERWISW HIT
   357                                  collision_hit:
   358 000002F1 E871FDFFFF                  call    write_endl                  ; write ENDL
   359 000002F6 B9[D0010000]                mov     ecx, hit_msg                ; message 32 Bit Register
   360 000002FB BA07000000                  mov     edx, len_hit_msg            ; message length see length equ 32 Bit Register
   361 00000300 E848FDFFFF                  call    sys_write                   ; call sys_write   
   362 00000305 E85DFDFFFF                  call    write_endl                  ; write ENDL
   363 0000030A C3                          ret                                 ; RETURN FROM COLLISION: SUBROUTINE
   364                                  
   365                                  collision_miss:
   366 0000030B E857FDFFFF                  call    write_endl                  ; write ENDL
   367 00000310 B9[D7010000]                mov     ecx, miss_msg               ; message 32 Bit Register
   368 00000315 BA05000000                  mov     edx, len_miss_msg           ; message length see length equ 32 Bit Register
   369 0000031A E82EFDFFFF                  call    sys_write                   ; call sys_write   
   370 0000031F E843FDFFFF                  call    write_endl                  ; write ENDL
   371 00000324 C3                          ret                                 ; RETURN FROM COLLISION: SUBROUTINE   
   372                                  
   373                                  ;-------------------------------------------------------
   374                                  ;----Convert Number into Printable String---------------
   375                                  ; Step through each digit and display
   376                                  ;-------------------------------------------------------
   377                                  int_to_string:
   378 00000325 83C609                      add     esi, 9                      ; 0-9 Bytes    
   379 00000328 C60600                      mov     byte [esi], 0               ; String terminator
   380                                      
   381 0000032B BB0A000000                  mov     ebx, 10                     ; Move 10 (divide each digit by 10)
   382                                  
   383                                  .next_digit:
   384 00000330 31D2                        xor     edx, edx                    ; clear edx register
   385 00000332 F7F3                        div     ebx                         ; eax /= 10
   386 00000334 80C230                      add     dl, '0'                     ; Convert the remainder to ASCII 
   387 00000337 4E                          dec     esi                         ; Store characters in reverse order
   388 00000338 8816                        mov     [esi], dl                   ; Move DL register to ESI
   389 0000033A 85C0                        test    eax, eax                    ; Perform a bitwise AND on two operands                   
   390 0000033C 75F2                        jnz     .next_digit                 ; Repeat until eax == 0
   391 0000033E 89F0                        mov     eax, esi                    ; Memory address of first Digit
   392 00000340 C3                          ret
   393                                  
   394                                  ;-------------------------------------------------------
   395                                  ;------------------CLEAR SCREEN-------------------------
   396                                  ;-------------------------------------------------------
   397                                  clear_screen:
   398 00000341 B9[00000000]                mov     ecx, clear_escape           ; Terminal control string
   399 00000346 BA07000000                  mov     edx, len_clear_escape       ; clear_escape message length
   400 0000034B E8FDFCFFFF                  call    sys_write                   ; call sys_write
   401 00000350 C3                          ret
   402                                  
   403                                  ;-------------------------------------------------------
   404                                  ;------------------CONTINUE-----------------------------
   405                                  ;-------------------------------------------------------
   406                                  continue:
   407 00000351 B9[02000000]                mov     ecx, anykey                 ; move input to anykey  
   408 00000356 BA01000000                  mov     edx, 1                      ; size of input
   409 0000035B E8FAFCFFFF                  call    sys_read                    ; call sys_read
   410 00000360 C3                          ret                                 ; return
   411                                  
   412                                  ;-------------------------------------------------------
   413                                  ;------------------Flush Line Feed----------------------
   414                                  ;-------------------------------------------------------
   415                                  flush:
   416 00000361 B9[13000000]                mov     ecx, flush_buffer           ; message 32 Bit Register
   417 00000366 BA01000000                  mov     edx, len_flush_buffer       ; message length see length equ 32 Bit Register
   418 0000036B E8EAFCFFFF                  call    sys_read                    ; call sys_read
   419 00000370 807C11FF0A                  cmp     byte [ecx + edx - 1], 0xA   ; cmp line feed
   420 00000375 75EA                        jne     flush                       ; loop again
   421 00000377 C3                          ret                                 ; return
   422                                  
   423                                  ;-------------------------------------------------------
   424                                  ;------------------Default Terminal---------------------
   425                                  ;-------------------------------------------------------
   426                                  default_terminal:
   427 00000378 B9[07000000]                mov     ecx, terminal_default       ; message 32 Bit Register
   428 0000037D BA0A000000                  mov     edx, len_terminal_default   ; message length see length equ 32 Bit Register
   429 00000382 E8C6FCFFFF                  call    sys_write                   ; call sys_write 
   430 00000387 E8DBFCFFFF                  call    write_endl                  ; write ENDL
   431 0000038C C3                          ret                                 ; return  
   432                                  
   433                                  ;-------------------------------------------------------
   434                                  ;---------------------Red Terminal----------------------
   435                                  ;-------------------------------------------------------
