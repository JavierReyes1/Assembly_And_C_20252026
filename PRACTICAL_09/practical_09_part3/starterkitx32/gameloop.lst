   273 0000021C C3                          ret                                 ; RETURN FROM HUD: SUBROUTINE
   274                                  
   275                                  .hud_score:
   276 0000021D E845FEFFFF                  call    write_endl                  ; write ENDL
   277 00000222 B9[45020000]                mov     ecx, score_msg              ; message 32 Bit Register
   278 00000227 BA08000000                  mov     edx, len_score_msg          ; message length see length equ 32 Bit Register
   279 0000022C E81CFEFFFF                  call    sys_write                   ; call sys_write   
   280                                  
   281 00000231 A1[03000000]                mov     eax, [score]                ; Pass number to eax
   282 00000236 BE[0F000000]                mov     esi, buffer                 ; Size of Buffer
   283                                      
   284 0000023B E8E5000000                  call    int_to_string               ; Call int_to_string
   285                                  
   286 00000240 89C1                        mov     ecx, eax                    ; Result in eax, pass to ecx to print                 
   287 00000242 BA04000000                  mov     edx, 0x4                    ; message length see length equ 32 Bit Register
   288                                  
   289 00000247 E801FEFFFF                  call    sys_write                   ; call sys_write   
   290 0000024C E816FEFFFF                  call    write_endl                  ; write ENDL
   291 00000251 C3                          ret                                 ; return
   292                                  
   293                                  .hud_health:
   294 00000252 B9[4D020000]                mov     ecx, health_msg             ; message 32 Bit Register
   295 00000257 BA09000000                  mov     edx, len_health_msg         ; message length see length equ 32 Bit Register
   296 0000025C E8ECFDFFFF                  call    sys_write                   ; call sys_write   
   297                                  
   298 00000261 A1[07000000]                mov     eax, [health]               ; Pass number to eax
   299 00000266 BE[0F000000]                mov     esi, buffer                 ; Size of Buffer
   300                                      
   301 0000026B E8B5000000                  call    int_to_string               ; Call int_to_string
   302                                  
   303 00000270 89C1                        mov     ecx, eax                    ; Result in eax, pass to ecx to print                 
   304 00000272 BA04000000                  mov     edx, 0x4                    ; message length see length equ 32 Bit Register
   305                                  
   306 00000277 E8D1FDFFFF                  call    sys_write                   ; call sys_write   
   307 0000027C E8E6FDFFFF                  call    write_endl                  ; write ENDL
   308 00000281 C3                          ret
   309                                  
