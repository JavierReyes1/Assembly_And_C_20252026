   139 000000D8 B9[01010000]                mov     ecx, potion_msg             ; message 32 Bit Register
   140 000000DD BA1D000000                  mov     edx, len_potion_msg         ; message length see length equ 32 Bit Register
   141 000000E2 E866FFFFFF                  call    sys_write                   ; call sys_write    
   142 000000E7 E87BFFFFFF                  call    write_endl                  ; write ENDL
   143 000000EC B9[1E010000]                mov     ecx, potions_msg            ; message 32 Bit Register
   144 000000F1 BA15000000                  mov     edx, len_potions_msg        ; message length see length equ 32 Bit Register
   145 000000F6 E86CFFFFFF                  call    write_endl                  ; write ENDL
   146 000000FB E84DFFFFFF                  call    sys_write                   ; call sys_write    
