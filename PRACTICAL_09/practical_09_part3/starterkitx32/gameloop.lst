   464                                  section .bss
   465 00000000 ??                          counter resb 1                      ; reserve a byte of memory for counter
   466 00000001 ??                          action  resb 1                      ; reserve a byte of memory for action
   467 00000002 ??                          anykey  resb 1                      ; reserve a byte of memory for anykey
   468 00000003 ????????                    score   resb 4                      ; reserve a byte of memory for score
   469 00000007 ????????                    health  resb 4                      ; reserve a byte of memory for health
   470 0000000B ????????                    number  resb 4                      ; reserve a byte of memory for buffer atoi
   471 0000000F ????????                    buffer  resb 4                      ; reserve a byte of memory for buffer atoi
   472 00000013 ??                          flush_buffer        resb 1              ; flush buffer
   473                                      len_flush_buffer    equ $-flush_buffer  ; flush buffer length   
   474 00000014 ??                          row     resb 1                      ; reserve a byte or memory for row
   475 00000015 ??                          col     resb 1                      ; reserve a byte or memory for column
