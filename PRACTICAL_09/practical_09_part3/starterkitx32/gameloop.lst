     2                                  
     3                                  ;-------------------------------------------------------
     4                                  ; CHOOSE TO BE A HERO OR A VILLIAN 
     5                                  ;-------------------------------------------------------
     6                                  
     7                                  ;-------------------------------------------------------
     8                                  ; VALIDATION VALUES TO BE USED, MODIFY AS NEEDED
     9                                  ; ADD ADDITIONAL VALIDATION VALUES AS REQUIRED
    10                                  ;-------------------------------------------------------
    11                                  MIN_POTIONS EQU 1                       ; MIN NUMBER OF POTIONS
    12                                  MAX_POTIONS EQU 9                       ; MAX NUMBER OF POTIONS
    13                                  MIN_WEAPONS EQU 1                       ; MIN WEAPONS
    14                                  MAX_WEAPONS EQU 3                       ; MAX WEAPONS
    15                                  WIN_POINT   EQU 5                       ; POINTS ACCUMILATED ON WIN
    16                                  LOSE_POINT  EQU 8                       ; POINTS DEDUCTED ON A LOSS
    17                                  
    18                                  MAX_HEALTH  EQU 100                     ; Max Health
    19                                  MIN_HEALTH  EQU 0                       ; Min Health
    20                                  LOSE_HEALTH EQU 10                      ; POINTS DEDUCTED ON A LOSS
    21                                  
    22                                  MINE_LOC    EQU 100                     ; USED BELOW FOR SOME SIMPLE COLLISION DETECTION USING CMP
    23                                                                          ; EXAMPLE FOR A HIT
    24                                  SCORE_INIT  EQU 0                       ; Initialize Scroe at 0
    25                                  SCORE_INC   EQU 100                     ; Score increment
    26                                  SCORE_VAL   EQU 9900                    ; Last possible score value, after this set to 9999
    27                                  MAX_SCORE   EQU 9999                    ; Max Score
    28                                  
    29                                  STATUS_OK   EQU 0x00                    ; return status okay
    30                                  SYS_EXIT    EQU 0x01                    ; system exit
    31                                  SYS_KERNEL  EQU 0x80                    ; kernel call
    32                                  SYS_READ    EQU 0x03                    ; System read
    33                                  SYS_STDIN   EQU 0x02                    ; stdin
    34                                  SYS_STDOUT  EQU 0x01                    ; stdout
    35                                  SYS_WRITE   EQU 0x04                    ; System write
    36                                  
    37                                  ;-------------------------------------------------------
    38                                  ;--------------------Globals----------------------------
    39                                  ;-------------------------------------------------------
    40                                  global _start                           ; Declared for linker this is declaring _start (entry point)
    41                                  
    42                                  ;-------------------------------------------------------
    43                                  ;--------------------Entry Point------------------------
    44                                  ;-------------------------------------------------------	
    45                                  _start: ;linker entry point
    46 00000000 E83C030000                  call    clear_screen                ; CLEARS THE SCREEN 
    47 00000005 E86D000000                  call    initialize                  ; Initialize Game Data
    48 0000000A E87E030000                  call    red_terminal                ; Red Terminal
    49 0000000F E87C000000                  call    welcome                     ; Branch to Welcome Procedure
    50 00000014 E838030000                  call    continue                    ; Press anykey to continue
    51 00000019 E823030000                  call    clear_screen                ; CLEARS THE SCREEN 
    52 0000001E E894030000                  call    blue_terminal               ; Blue Terminal
    53 00000023 E887000000                  call    game_input                  ; Branch to Game Input Procedure
    54 00000028 E824030000                  call    continue                    ; Press anykey to continue 
    55 0000002D E846030000                  call    default_terminal            ; Default Terminal
    56 00000032 E8E4000000                  call    game                        ; Branch to Game Procedure
    57 00000037 E825030000                  call    flush                       ; Flush before exit
    58 0000003C E800000000                  call    system_exit                 ; Exit and Clean Up
    59                                  
    60                                  ;-------------------------------------------------------
    61                                  ;--------------------System Exit------------------------
    62                                  ;-------------------------------------------------------
    63                                  system_exit:
    64 00000041 BB00000000                  mov     ebx, STATUS_OK              ; return status 32 Bit Registerr
    65 00000046 B801000000                  mov     eax, SYS_EXIT               ; system call number (sys_exit) 32 Bit Register
    66 0000004B CD80                        int     SYS_KERNEL                  ; call kernel, system call 32 bit System  
    67                                  
    68                                  ;-------------------------------------------------------
    69                                  ;-------------------Write to stdout---------------------
    70                                  ;-------------------------------------------------------
    71                                  sys_write:
    72 0000004D BB01000000                  mov     ebx, SYS_STDOUT             ; file descriptor (stdout) 32 Bit Register
    73 00000052 B804000000                  mov     eax, SYS_WRITE              ; system call number (sys_write) 32 Bit Register
    74 00000057 CD80                        int     SYS_KERNEL                  ; call kernel, system call 32 bit System
    75 00000059 C3                          ret                                 ; return
    76                                  
    77                                  ;-------------------------------------------------------
    78                                  ;-------------------Read from stdin---------------------
    79                                  ;-------------------------------------------------------
    80                                  sys_read:
    81 0000005A BB02000000                  mov     ebx, SYS_STDIN              ; file descriptor (stdin) 32 Bit Register
    82 0000005F B803000000                  mov     eax, SYS_READ               ; system call number (sys_read) 32 Bit Register    
    83 00000064 CD80                        int     SYS_KERNEL                  ; call kernel, system call 32 bit System
    84 00000066 C3                          ret                                 ; return
    85                                  
    86                                  ;-------------------------------------------------------
    87                                  ;---------------------Write ENDL------------------------
    88                                  ;-------------------------------------------------------
    89                                  write_endl:
    90 00000067 B9[56020000]                mov     ecx, crlf                   ; message 32 Bit Register
    91 0000006C BA02000000                  mov     edx, len_crlf               ; message length see length equ 32 Bit Register
    92 00000071 E8D7FFFFFF                  call    sys_write                   ; call sys_write
    93 00000076 C3                          ret                                 ; return
    94                                  
    95                                  ;-------------------------------------------------------
    96                                  ;----------------Initialize SUBROUTINE------------------
    97                                  ;-------------------------------------------------------
    98                                  initialize:
    99 00000077 31C0                        xor     eax, eax                    ; clear eax accumulator register
   100 00000079 B800000000                  mov     eax, SCORE_INIT             ; Moves 0 to Score
   101 0000007E A3[03000000]                mov     [score], eax                ; Initialize score at 0
   102                                  
   103 00000083 31C0                        xor     eax, eax                    ; clear eax accumulator register
   104 00000085 B864000000                  mov     eax, MAX_HEALTH             ; Moves 100 to Health
   105 0000008A A3[07000000]                mov     [health], eax               ; Initialize score at 0
   106 0000008F C3                          ret
   107                                  
   108                                  ;-------------------------------------------------------
   109                                  ;-------------------WELCOME SUBROUTINE------------------
   110                                  ;-------------------------------------------------------
   111                                  welcome:
   112 00000090 E8D2FFFFFF                  call    write_endl                  ; write ENDL
   113 00000095 B9[25000000]                mov     ecx, welcome_msg            ; message 32 Bit Register
   114 0000009A BAB9000000                  mov     edx, len_welcome_msg        ; message length see length equ 32 Bit Register
   115 0000009F E8A9FFFFFF                  call    sys_write                   ; call sys_write  
   116 000000A4 E8BEFFFFFF                  call    write_endl                  ; write ENDL
   117 000000A9 E8D4010000                  call    write_continue              ; call continue
   118 000000AE C3                          ret                                 ; return
   119                                  
