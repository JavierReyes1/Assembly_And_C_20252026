   125 000000B4 E81A000000                  call    potions_input               ; BRANCH TO POTION INPUT SUBROUTINE
   126 000000B9 E80D020000                  call    decorate                    ; Decorate screen
   127 000000BE E83E000000                  call    weapons_input               ; BRANCH TO WEAPONSS INPUT SUBROUTINE
   128 000000C3 E89FFFFFFF                  call    write_endl                  ; write ENDL
   129 000000C8 E8FE010000                  call    decorate                    ; Decorate screen
   130 000000CD E8B0010000                  call    write_continue              ; call continue msg
   131 000000D2 C3                          ret                                 ; return
