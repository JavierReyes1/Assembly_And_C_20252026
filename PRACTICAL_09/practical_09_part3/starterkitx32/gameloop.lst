   442                                  ;-------------------------------------------------------
   443                                  ;--------------------Green Terminal---------------------
   444                                  ;-------------------------------------------------------
   445                                  green_terminal: 
   446 000003A2 B9[16000000]                mov     ecx, terminal_green         ; message 32 Bit Register
   447 000003A7 BA0A000000                  mov     edx, len_terminal_green     ; message length see length equ 32 Bit Register
   448 000003AC E89CFCFFFF                  call    sys_write                   ; call sys_write 
   449 000003B1 E8B1FCFFFF                  call    write_endl                  ; write ENDL
   450 000003B6 C3                          ret                                 ; return
   451                                  ;-------------------------------------------------------
   452                                  ;--------------------Blue Terminal----------------------
   453                                  ;-------------------------------------------------------
   454                                  blue_terminal:
   455 000003B7 B9[20000000]                mov     ecx, terminal_blue          ; message 32 Bit Register
   456 000003BC BA05000000                  mov     edx, len_terminal_blue      ; message length see length equ 32 Bit Register
   457 000003C1 E887FCFFFF                  call    sys_write                   ; call sys_write 
   458 000003C6 E89CFCFFFF                  call    write_endl                  ; write ENDL
   459 000003CB C3                          ret                                 ; return 
