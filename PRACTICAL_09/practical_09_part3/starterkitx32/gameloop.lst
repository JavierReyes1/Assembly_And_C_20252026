   248 000001E3 B9[C3010000]                mov     ecx, draw_msg               ; message 32 Bit Register
   249 000001E8 BA0D000000                  mov     edx, len_draw_msg           ; message length see length equ 32 Bit Register
   250 000001ED E85BFEFFFF                  call    sys_write                   ; call sys_write   
   251 000001F2 E870FEFFFF                  call    write_endl                  ; write ENDL
