   162                                  ;-------------------GAME SUBROUTINE---------------------
   163                                  ;-------------------------------------------------------
   164                                  game:
   165 0000011B E801000000                  call    gameloop                    ; BRANCH TO GAMELOOP SUBROUTINE
   166 00000120 C3                          ret                                 ; RETURN FROM GAME: SUBROUTINE
   167                                  
   168                                  ;-------------------------------------------------------
   169                                  ;----------------GAMELOOP (MAIN LOOP)-------------------
   170                                  ;------------------------------------------------------- 
   171                                  gameloop:
   172 00000121 E81B020000                  call    clear_screen                ; CLEARS THE SCREEN 
   173 00000126 E8A0010000                  call    decorate                    ; Decorate screen
   174 0000012B E83D000000                  call    update                      ; BRANCH TO UPDATE GAME SUBROUTINE 
   175 00000130 E896010000                  call    decorate                    ; Decorate screen
   176 00000135 E8A4000000                  call    draw                        ; BRANCH TO DRAW SCREEN SUBROUTINE
   177 0000013A E88C010000                  call    decorate                    ; Decorate screen
   178 0000013F E8B4000000                  call    gameplay                    ; BRANCH TO GAMEPLAY SCREEN SUBROUTINE
   179 00000144 E882010000                  call    decorate                    ; Decorate screen
   180 00000149 E854020000                  call    green_terminal              ; Green Terminal
   181 0000014E E8BF000000                  call    hud                         ; BRANCH TO DISPLAY HUD SUBROUTINE
   182 00000153 E820020000                  call    default_terminal            ; Default Terminal
   183 00000158 E86E010000                  call    decorate                    ; Decorate screen
   184 0000015D E883010000                  call    collision                   ; BRANCH TO COLLISION SUBROUTINE
   185 00000162 E864010000                  call    decorate                    ; Decorate screen
   186 00000167 E82B010000                  call    replay                      ; BRANCH TO REPLAY GAME SUBROUTINE
   187 0000016C C3                          ret                                 ; RETURN FROM GAMELOOP: SUBROUTINE
   188                                  
   189                                  ;-------------------------------------------------------
   190                                  ;----------------UPDATE QUEST PROGRESS------------------
   191                                  ;  COMPLETE QUEST
   192                                  ;------------------------------------------------------- 
   193                                  update:
   194 0000016D E8F5FEFFFF                  call    write_endl                  ; write ENDL
   195 00000172 B9[B2010000]                mov     ecx, update_msg             ; message 32 Bit Register
   196 00000177 BA11000000                  mov     edx, len_update_msg         ; message length see length equ 32 Bit Register
   197 0000017C E8CCFEFFFF                  call    sys_write                   ; call sys_write   
   198 00000181 E8E1FEFFFF                  call    write_endl                  ; write ENDL
   199                                  
   200 00000186 E806000000                  call    .update_score               ; update score    
   201 0000018B E829000000                  call    .update_health              ; update health 
   202                                  
   203 00000190 C3                          ret                                 ; RETURN FROM UPDATE: SUBROUTINE
   204                                  
   205                                  .update_score:
   206 00000191 31C0                        xor     eax, eax                    ; clear eax accumulator register
   207 00000193 A1[03000000]                mov     eax, [score]                ; fetch score
   208                                     
   209 00000198 89C1                        mov     ecx, eax                    ; move to ecx for comparison
   210 0000019A 81F9AC260000                cmp     ecx, SCORE_VAL              ; Check is score is less than SCORE_VAL
   211 000001A0 7C0C                        jl      .set_score                  ; set score 
   212                                  .set_score_max:    
   213 000001A2 B80F270000                  mov     eax, MAX_SCORE              ; set score to MAX_SCORE
   214 000001A7 A3[03000000]                mov     [score], eax                ; update score
   215 000001AC EB0A                        jmp     .end_update_score           ; goto end or procedure
   216                                  .set_score:
   217 000001AE 83C064                      add     eax, SCORE_INC              ; increment score by SCORE_INC per round
   218 000001B1 A3[03000000]                mov     [score], eax                ; update score
   219 000001B6 EB00                        jmp     .end_update_score           ; goto end or procedure
   220                                  .end_update_score:
   221 000001B8 C3                          ret                                 ; return
   222                                      
   223                                  .update_health:
   224 000001B9 31C0                        xor     eax, eax                    ; clear eax accumulator register
   225 000001BB A1[07000000]                mov     eax, [health]               ; fetch health
   226                                      
   227 000001C0 89C1                        mov     ecx, eax
   228 000001C2 83F90A                      cmp     ecx, LOSE_HEALTH            ; Check is health remaining is greater than LOSE_HEALTH
   229 000001C5 7D0C                        jge     .set_health                 ; set health
   230                                  .set_health_zero:    
   231 000001C7 B800000000                  mov     eax, MIN_HEALTH             ; set health to 0
   232 000001CC A3[07000000]                mov     [health], eax               ; update health
   233 000001D1 EB0A                        jmp     .end_update_health          ; goto end or procedure
   234                                  .set_health:
   235 000001D3 83E80A                      sub     eax, LOSE_HEALTH            ; decrement health by 10 per round (TODO Change GSM when Health reached 0)
   236 000001D6 A3[07000000]                mov     [health], eax               ; update health
   237 000001DB EB00                        jmp     .end_update_health          ; goto end or procedure
   238                                  .end_update_health:
   239 000001DD C3                          ret                                 ; return
   240                                  
